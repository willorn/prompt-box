{
  "name": "prompt-box-electron",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "bun@1.3.4",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "bd": "bun dev",
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac --dir",
    "preview:ui": "bash ./scripts/preview-packaged-ui.sh"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-store": "^9.0.0",
    "webdav": "^5.9.0"
  },
  "build": {
    "appId": "com.promptmaster.desktop",
    "productName": "PromptBox",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "extendInfo": {
        "LSUIElement": true
      },
      "icon": "assets/icon.icns"
    },
    "asar": true,
    "icon": "assets/icon.icns"
  },
  "description": "PromptBox - 桌面提示词快速调用工具",
  "author": "PromptBox"
}
